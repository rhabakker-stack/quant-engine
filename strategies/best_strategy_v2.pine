//@version=6
strategy("MACD+RSI+EMA Filtered v2", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital=10000, commission_value=0.04, slippage=1, calc_on_every_tick=false)

// ── Inputs ──────────────────────────────────────────────────────
// MACD
macdFast     = input.int(8, "MACD Fast", minval=2)
macdSlow     = input.int(21, "MACD Slow", minval=5)
macdSignal   = input.int(5, "MACD Signal", minval=2)

// RSI Filter
rsiPeriod    = input.int(14, "RSI Period", minval=2)
rsiMin       = input.float(30.0, "RSI Entry Min", step=1)
rsiMax       = input.float(60.0, "RSI Entry Max", step=1)

// Trend Filter
emaTrend     = input.int(50, "EMA Trend Filter", minval=10)

// Risk Management (ATR-based)
atrPeriod    = input.int(14, "ATR Period", minval=1)
slAtrMult    = input.float(2.0, "Stop Loss ATR Mult", step=0.1, minval=0.5)
tpAtrMult    = input.float(5.0, "Take Profit ATR Mult", step=0.1, minval=1.0)
trailMult    = input.float(2.5, "Trailing Stop ATR Mult", step=0.1, minval=0.5)
trailDelay   = input.int(3, "Trail Activation Bars", minval=1, tooltip="Start trailing after N bars")

// ── Indicators ──────────────────────────────────────────────────
[macdLine, signalLine, histLine] = ta.macd(close, macdFast, macdSlow, macdSignal)
rsiVal = ta.rsi(close, rsiPeriod)
atrVal = ta.atr(atrPeriod)
emaTrendLine = ta.ema(close, emaTrend)

// ── Entry Conditions ────────────────────────────────────────────
macdCrossUp   = ta.crossover(macdLine, signalLine)
rsiInZone     = rsiVal >= rsiMin and rsiVal <= rsiMax
aboveTrend    = close > emaTrendLine
histPositive  = histLine > 0

longCondition = macdCrossUp and rsiInZone and aboveTrend and histPositive and atrVal > 0

// ── State Variables ─────────────────────────────────────────────
var float entryPrice        = na
var float slPrice           = na
var float tpPrice           = na
var float trailStopPrice    = na
var float highestSinceEntry = na
var float entryATR          = na
var int   entryBarIdx       = na

// ── Entry ───────────────────────────────────────────────────────
if longCondition and strategy.position_size == 0
    entryPrice        := close
    entryATR          := atrVal
    slPrice           := close - slAtrMult * atrVal
    tpPrice           := close + tpAtrMult * atrVal
    trailStopPrice    := close - trailMult * atrVal
    highestSinceEntry := close
    entryBarIdx       := bar_index
    strategy.entry("Long", strategy.long)

// ── Exit Management ─────────────────────────────────────────────
if strategy.position_size > 0
    barsHeld = bar_index - entryBarIdx

    // Update highest since entry
    if high > highestSinceEntry
        highestSinceEntry := high

    // Update trailing stop after delay
    if barsHeld > trailDelay
        newTrail       = highestSinceEntry - trailMult * entryATR
        trailStopPrice := math.max(trailStopPrice, newTrail)

    // Fixed SL and TP via strategy.exit (TV handles intra-bar execution)
    strategy.exit("SL/TP", "Long", stop=slPrice, limit=tpPrice)

    // Trailing stop (manual close for tighter control)
    if close <= trailStopPrice and barsHeld > trailDelay
        strategy.close("Long", comment="Trail")

    // MACD signal exit: close on crossunder if in profit or held long enough
    if ta.crossunder(macdLine, signalLine) and (close > entryPrice or barsHeld > 5)
        strategy.close("Long", comment="MACD Exit")

// ── Plots ───────────────────────────────────────────────────────
plot(emaTrendLine, "EMA Trend", color=color.new(color.orange, 30), linewidth=2)

// Entry signals
plotshape(longCondition and strategy.position_size == 0, title="Buy", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.small)

// SL/TP/Trail lines
inPos = strategy.position_size > 0
plot(inPos ? slPrice : na, "Stop Loss", color=color.red, style=plot.style_linebr, linewidth=1)
plot(inPos ? tpPrice : na, "Take Profit", color=color.green, style=plot.style_linebr, linewidth=1)
plot(inPos ? trailStopPrice : na, "Trail Stop", color=color.orange, style=plot.style_linebr, linewidth=1)

// Position background
bgcolor(inPos ? color.new(color.green, 95) : na, title="In Position")

// ── Info Table ──────────────────────────────────────────────────
var table infoTable = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(infoTable, 0, 0, "MACD", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, str.tostring(macdLine, "#.##") + " / " + str.tostring(signalLine, "#.##"), text_color=macdLine > signalLine ? color.green : color.red, text_size=size.small)
    table.cell(infoTable, 0, 1, "RSI", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(rsiVal, "#.#"), text_color=rsiInZone ? color.green : color.gray, text_size=size.small)
    table.cell(infoTable, 0, 2, "ATR", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(atrVal, "#.##"), text_color=color.white, text_size=size.small)
    table.cell(infoTable, 0, 3, "Trend", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, aboveTrend ? "BULL" : "BEAR", text_color=aboveTrend ? color.green : color.red, text_size=size.small)
    table.cell(infoTable, 0, 4, "Position", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 4, inPos ? "LONG" : "FLAT", text_color=inPos ? color.green : color.gray, text_size=size.small)
